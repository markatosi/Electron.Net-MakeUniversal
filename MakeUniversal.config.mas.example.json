{
  "appName": "ExampleApp",
  "projectRoot": "..",
  "buildCwd": "..",
  "publishProfiles": {
    "osxX64": "publish-osx-x64",
    "osxArm64": "publish-osx-arm64"
  },
  "signIdentity": "Apple Distribution: Your Name (TEAMID)",
  "macSigning": {
    "defaults": {
      "type": "distribution",
      "timestamp": "http://timestamp.apple.com/ts01",
      "gatekeeperAssess": false,
      "verbose": true,
      "extraOptions": {
        "identity-validation": false
      }
    },
    "targets": {
      "mas": {
        "entitlements": "entitlements.mas.plist",
        "entitlementsInherit": "entitlements.mas.inherit.plist",
        "provisioningProfile": "Development.provisionprofile",
        "platform": "mas",
        "type": "distribution",
        "hardenedRuntime": false,
        "extraOptions": {}
      }
    }
  }
}

